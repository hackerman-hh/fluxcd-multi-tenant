name: Parse Issue

on:
  issues:
    types: [opened, edited]

jobs:
  parse:
    runs-on: ubuntu-latest
    permissions:
      issues: write

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v7

      - name: Parse Issue Body
        id: issue-parser
        uses: stefanbuck/github-issue-parser@v3
        with:
          template-path: .github/ISSUE_TEMPLATE/new-tenant.yml

      - name: Debug and Extract Parsed Data
        env:
          # We grab the raw JSON object string directly from the action
          RAW_JSON: ${{ steps.issue-parser.outputs.jsonString }}
        run: |
          # 1. Print the raw JSON to your logs so you can see the exact keys
          echo "--- RAW PARSED JSON DATA ---"
          echo "$RAW_JSON"
          echo "----------------------------"
          
          # 2. Extract values safely using 'jq' based on your Markdown fields
          # (Note: jq keys are case-sensitive and match your template IDs)
          TENANT=$(echo "$RAW_JSON" | jq -r '."tenant_id" // ."tenant-id" // ."Tenant ID" // empty')
          WHAT=$(echo "$RAW_JSON" | jq -r '."what-happened" // ."what_happened" // empty')
          ENVIRONMENTS=$(echo "$RAW_JSON" | jq -c '."environments" // ."Environments" // empty')
          
          # 3. Echo the final extracted data
          echo "Tenant: ${TENANT}"
          echo "Environments: ${ENVIRONMENTS}"
          echo "what-happened: ${WHAT}"

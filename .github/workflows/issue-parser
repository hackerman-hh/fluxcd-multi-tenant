name: Parse Issue

on:
  issues:
    types: [opened, edited]

jobs:
  parse:
    runs-on: ubuntu-latest
    # Optional: Grant permissions if you plan to comment or modify the issue later
    permissions:
      issues: write

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v7

      - name: Parse Issue Body
        id: issue-parser
        uses: stefanbuck/github-issue-parser@v3
        with:
          template-path: .github/ISSUE_TEMPLATE/new-tenant.yml
        run: cat ${HOME}/issue-parser-result.json

      - name: Use Parsed Data
        env:
          ENVIRONMENTS: ${{ steps.issue-parser.outputs.environments }}
          TENANT: "${{ steps.issue-parser.outputs.tenant_id }}"
          WHAT: "${{ steps.issue-parser.outputs.what-happened }}"
        run: |
          echo "what-happened: ${WHAT}"
          echo "Environments: ${ENVIRONMENTS}"
          echo "Tenant: ${TENANT}"
